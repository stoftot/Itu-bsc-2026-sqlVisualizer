@page "/"
@using visualizer.Components.Shared
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>
<div class="layout">
    
    <SchemaView
        OnTableSelected="HandTabledSchemaTableSelected"
    />
    
    <main class="main-content">
        <div class="view">
            @if (viewVisulisation)
            {
                <QueryIlustrationView @ref="QueryView" Query="@_query"/>
            }
            else
            {
                <TableView @key="@Guid.NewGuid()"
                           Table="tableSelected"/>
            }
        </div>

        <div class="toolbar">
            <ToolBar
                RunQueryCallback="RunQueryCallback"
                />
        </div>
        
        <div class="editor">
            <EditorView />
        </div>
    </main>
</div>
