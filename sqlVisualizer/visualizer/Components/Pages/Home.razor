@page "/"
@using visualizer.Components.Shared
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>
<div class="layout">
    
    @if (HomeState.ViewSidebar)
    {
        <SchemaView OnTableSelected="HandTabledSchemaTableSelected" />
    }
    
    <main class="main-content">
        <div class="view">
            @if (HomeState.IsViewingTable)
            {
                <TableView @key="@Guid.NewGuid()" Table="tableSelected"/>
            }
            else
            {
                <QueryIlustrationView @ref="QueryView" Query="@_query"/>
            }
        </div>

        <ToolBar RunQueryCallback="RunQueryCallback" />
    
        <EditorView />
    </main>
    
    <ErrorPopup/>
</div>
