@inherits TableViewBase
@if (Table is null)
{
    <div class="alert alert-warning" role="alert">
        No table to display
    </div>
}
else
{
    <div class="container">
        <div class="row align-items-center">
                <div class="@(ShowAggregation ? "col-10" : "col-12")">
                    <table class="table table-striped table-bordered table-sm">
                        <thead class="table-dark table-header-sm">
                        <tr>
                            @foreach (var columnName in Table.ColumnNames)
                            {
                                <th scope="col">@columnName</th>
                            }
                        </tr>
                        </thead>

                        <tbody class="table-body-sm fw-bolder">
                        @foreach (var entry in Table.Entries.Where(e => e.IsVisible))
                        {
                            <tr style="@(entry.IsHighlighted ? entry.GetHighlightStyle() : null)">
                                @foreach (var cell in entry.Values)
                                {
                                    <td style="@cell.GetStyle()">@cell.Value</td>
                                }
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                @if (ShowAggregation) 
                {
                    <div class="col-auto">
                        @foreach (var aggr in Table.Aggregations)
                        {
                            <div style="@(aggr.IsHighlighted ? $"background-color: {aggr.HexBackGroundColor}" : null)" class="aggregation-text-line">@aggr.Name = @aggr.Value</div>
                        }
                    </div>
                }
            </div>
        </div>
}